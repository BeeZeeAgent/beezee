{
  "name": "beezee",
  "version": "0.1.0",
  "description": "Launch and manage Claude Code and Codex sessions from any device",
  "type": "module",
  "bin": {
    "beezee": "./server.js"
  },
  "scripts": {
    "start": "bun server.js",
    "dev": "bun --watch server.js",
    "build:frontend": "cd frontend && npm run build",
    "build:binary": "bun build --compile server.js --outfile beezee",
    "build": "npm run build:frontend && npm run build:binary"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "ws": "^8.21.0"
  },
  "keywords": [
    "claude",
    "codex",
    "ai",
    "session",
    "launcher"
  ],
  "license": "MIT"
}
