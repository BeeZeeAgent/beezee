PORT=8789
PUBLIC_URL=https://relay.yourdomain.com
BASE_DOMAIN=yourdomain.com
SESSION_SECRET=replace-with-a-long-random-secret
DATA_DIR=./data

# Stripe. Leave blank to use the built-in mock checkout while developing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SEAT=

